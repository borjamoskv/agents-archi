# ============================================================================
# SOVEREIGN LEDGER VALIDATOR — Pin Constraint File (iCE40-HX8K-CT256)
# Target: Lattice iCE40-HX8K Breakout Board
# Protocol: CHEMSTRAIN v1.0 / CORTEX-Persist C5-REAL
# ============================================================================

# -- System Clock (12MHz onboard oscillator) --
set_io clk              J3

# -- Active-Low Reset (directly mapped to a pushbutton on breakout) --
set_io rst_n            A16

# -- SPI Slave Interface (receives exergy/entropy/threshold from host) --
# Instead of 32 parallel GPIO pins, we use SPI to shift data in/out.
# The FPGA acts as SPI slave; the host Mac (via FTDI) is the master.
set_io spi_sclk         R11
set_io spi_mosi         P11
set_io spi_miso         P12
set_io spi_cs_n         R12

# -- UART TX (state telemetry back to host @ 115200 baud) --
set_io uart_tx          B10

# -- Direct Output Signals (active-high, directly readable by host or LEDs) --
set_io state_out[0]     D14
set_io state_out[1]     E14
set_io state_out[2]     F14
set_io ledger_commit    G14
set_io verification_gate B5

# -- Commit Trigger (directly from host GPIO or button) --
set_io commit_trigger   A1

# -- Sector ID (directly from DIP switches or host GPIO) --
set_io sector_id[0]     A2
set_io sector_id[1]     A3

# -- CHEMSTRAIN Mode (directly from DIP switch or host GPIO) --
set_io chemstrain_mode  A4

# -- Force Verify — Sovereign Emergency Override (C5-REAL) --
set_io force_verify     A5

# -- Audio I2S Interface (optional: external ADC/DAC) --
set_io audio_in[0]      C3
set_io audio_in[1]      C4
set_io audio_in[2]      C5
set_io audio_in[3]      C6
set_io audio_in[4]      C7
set_io audio_in[5]      C8
set_io audio_in[6]      C9
set_io audio_in[7]      C10
set_io audio_in[8]      C11
set_io audio_in[9]      C12
set_io audio_in[10]     C14
set_io audio_in[11]     D1
set_io audio_in[12]     D2
set_io audio_in[13]     D3
set_io audio_in[14]     D4
set_io audio_in[15]     D5

set_io audio_out[0]     E2
set_io audio_out[1]     E3
set_io audio_out[2]     E4
set_io audio_out[3]     E5
set_io audio_out[4]     E6
set_io audio_out[5]     E7
set_io audio_out[6]     E8
set_io audio_out[7]     E9
set_io audio_out[8]     E10
set_io audio_out[9]     E11
set_io audio_out[10]    F1
set_io audio_out[11]    F2
set_io audio_out[12]    F3
set_io audio_out[13]    F4
set_io audio_out[14]    F5
set_io audio_out[15]    F7

# -- Diagnostic LEDs (accent indicators on breakout board) --
# LED D2 = Heartbeat (clk alive)
# LED D3 = verification_gate mirror
# LED D4 = BREACH state
# LED D5 = THINKING state (TARP active)
